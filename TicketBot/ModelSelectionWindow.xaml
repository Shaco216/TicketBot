<Window x:Class="TicketBot.ModelSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TicketBot"
        Title="Modell auswählen" Height="420" Width="400" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
        <local:InstalledTextConverter x:Key="InstalledTextConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- Suche -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock FontWeight="Bold" FontSize="14" Text="Wähle ein LLM (Ollama)"/>
            <TextBlock x:Name="TxtStatus" FontSize="11" Foreground="Gray" Text="Status: Unbekannt" />
        </StackPanel>

        <!-- Endpoint Auswahl -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
            <RadioButton x:Name="RbLocalhost" Content="Localhost" IsChecked="True" Checked="EndpointOptionChanged" Margin="0,0,8,0"/>
            <RadioButton x:Name="RbCustom" Content="Custom" Checked="EndpointOptionChanged" Margin="0,0,8,0"/>
            <TextBox x:Name="TxtEndpoint" Width="220" Height="24" VerticalContentAlignment="Center" Margin="6,0,0,0" IsEnabled="{Binding IsChecked, ElementName=RbCustom}" />
            <Button Content="Test/Aktualisieren" Click="BtnTestEndpoint_Click" Margin="6,0,0,0" />
        </StackPanel>

        <!-- Suche -->
        <Button Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,5" x:Name="BtnSearch" Content="Suche" Width="90" Click="BtnSearch_Click"/>

        <ListBox x:Name="LstModels" Grid.Row="3" Margin="0,0,0,8" SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                                 Fill="{Binding Installed, Converter={StaticResource BoolToBrushConverter}}"/>
                        <TextBlock Text="{Binding Id}" VerticalAlignment="Center"/>
                        <TextBlock Text="  " />
                        <TextBlock Text="{Binding Installed, Converter={StaticResource InstalledTextConverter}}" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
            <Grid>
                <TextBox x:Name="TxtCustomModel" Width="240" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Eigenes Modell eingeben..." 
                           IsHitTestVisible="False"
                           Foreground="Gray"
                           Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           Visibility="{Binding Text.IsEmpty, ElementName=TxtCustomModel, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
            <Button Content="Als Auswahl" Width="100" Click="BtnUseCustom_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Abbrechen" Width="90" Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button x:Name="BtnInstall" Content="Installieren" Width="90" Margin="0,0,8,0" Click="BtnInstall_Click"
                    Visibility="{Binding SelectedItem.Installed, ElementName=LstModels, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                    IsEnabled="{Binding SelectedItem, ElementName=LstModels, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
            <Button x:Name="BtnStart" Content="Start" Width="90" Click="BtnStart_Click"
                    IsEnabled="{Binding SelectedItem.Installed, ElementName=LstModels}"/>
        </StackPanel>
    </Grid>
</Window>
