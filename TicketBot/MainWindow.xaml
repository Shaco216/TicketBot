<Window x:Class="TicketBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TicketBot"
        mc:Ignorable="d"
        Title="Ollama WPF Chat" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Ausgabe-Textfenster (Scrollbar aktiviert) -->
        <TextBox x:Name="TxtOutput" 
                 Grid.Row="0" 
                 Margin="0,0,0,10" 
                 TextWrapping="Wrap" 
                 VerticalScrollBarVisibility="Auto" 
                 IsReadOnly="True" 
                 Background="#F5F5F5" 
                 FontSize="14"/>

        <!-- Eingabebereich am unteren Rand -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtInput" 
                     Grid.Column="0" 
                     Height="35" 
                     VerticalContentAlignment="Center" 
                     FontSize="14" 
                     Margin="0,0,10,0"/>

            <Button x:Name="BtnSend" 
                    Grid.Column="1" 
                    Content="Senden" 
                    Width="80" 
                    Height="35" 
                    Click="BtnSend_Click" 
                    IsDefault="True"/>
        </Grid>
    </Grid>
</Window>
